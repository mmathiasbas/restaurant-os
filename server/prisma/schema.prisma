generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoMesa {
  vacia
  ocupada
  lista
  por_pagar
}

enum EstadoOrden {
  pendiente
  en_preparacion
  lista
  entregada
  pagada
  cancelada
}

enum Rol {
  administrador
  cocinero
  mesero
  cajero
}

enum EstadoJornada {
  abierto
  cerrado
}

model Usuario {
  id_usuario Int     @id @default(autoincrement())
  nombre     String
  rol        Rol
  telefono   String?
  correo     String  @unique
  contrasena String
  Ordenes    Orden[]
  ventas     Venta[]
}

model Carta {
  id_plato     Int         @id @default(autoincrement())
  nombre       String
  ingredientes String?
  precio       Decimal
  stock        Int         @default(0)
  orden_items  OrdenItem[]
}

model Mesa {
  id_mesa Int        @id
  estado  EstadoMesa @default(vacia)
  ordenes Orden[]
}

model Orden {
  id_orden     Int         @id @default(autoincrement())
  id_mesero    Int
  id_mesa      Int
  precio_total Decimal     @default(0)
  estado       EstadoOrden @default(pendiente)
  fecha_hora   DateTime    @default(now())
  mesero       Usuario     @relation(fields: [id_mesero], references: [id_usuario])
  mesa         Mesa        @relation(fields: [id_mesa], references: [id_mesa])
  items        OrdenItem[]
  venta        Venta?
}

model OrdenItem {
  id              Int     @id @default(autoincrement())
  id_orden        Int
  id_plato        Int
  cantidad        Int
  precio_unitario Decimal
  orden           Orden   @relation(fields: [id_orden], references: [id_orden])
  plato           Carta   @relation(fields: [id_plato], references: [id_plato])
}

model Jornada {
  id             Int           @id @default(autoincrement())
  fecha_apertura DateTime      @default(now())
  fecha_cierre   DateTime?
  estado         EstadoJornada @default(abierto)
}

model Venta {
  id          Int      @id @default(autoincrement())
  id_orden    Int      @unique
  id_cajero   Int
  monto       Decimal
  metodo_pago String
  fecha       DateTime @default(now())
  orden       Orden    @relation(fields: [id_orden], references: [id_orden])
  cajero      Usuario  @relation(fields: [id_cajero], references: [id_usuario])
}

model Actividad {
  id          Int      @id @default(autoincrement())
  tipo        String
  descripcion String
  fecha       DateTime @default(now())
}
